# ═══════════════════════════════════════════
# CrossFlow Mobility — Environment Variables
# Copy this file to .env.local and fill in values
# ═══════════════════════════════════════════

# Mapbox (required for map rendering)
# Get free token at: mapbox.com → Account → Tokens
NEXT_PUBLIC_MAPBOX_TOKEN=pk.eyJ1IjoiY3Jvc3NmbG93IiwiYSI6ImNrZXhhbXBsZSJ9.example

# TomTom Traffic API (2500 req/day free)
# Get key at: developer.tomtom.com
NEXT_PUBLIC_TOMTOM_API_KEY=your_tomtom_key_here

# HERE Traffic API (optional, fallback)
# Get key at: developer.here.com
NEXT_PUBLIC_HERE_API_KEY=your_here_key_here

# App config
NEXT_PUBLIC_APP_URL=http://localhost:3000
