# ═══════════════════════════════════════════════════════════
# CrossFlow Mobility — Variables d'environnement
# Copiez ce fichier en .env.local et renseignez vos valeurs
# Ne commitez JAMAIS .env.local (déjà dans .gitignore)
# ═══════════════════════════════════════════════════════════

# ── Application ──────────────────────────────────────────
# URL de l'application (localhost en dev, domaine prod sur Vercel)
NEXT_PUBLIC_APP_URL=http://localhost:3000

# ── Supabase (Auth + Base de données) ────────────────────
# Tableau de bord : https://supabase.com/dashboard/project/_/settings/api
NEXT_PUBLIC_SUPABASE_URL=https://xxxxxxxxxxxxxxxxxxxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# ── TomTom Traffic API ────────────────────────────────────
# Gratuit : 2 500 req/jour — https://developer.tomtom.com
NEXT_PUBLIC_TOMTOM_API_KEY=your_tomtom_key_here

# ── HERE Traffic API ─────────────────────────────────────
# Gratuit : 250 000 req/mois — https://developer.here.com
NEXT_PUBLIC_HERE_API_KEY=your_here_key_here

# ── OpenRouter AI (serveur uniquement) ───────────────────
# Clé privée, ne pas préfixer NEXT_PUBLIC_ — https://openrouter.ai/keys
OPENROUTER_API_KEY=sk-or-v1-your_openrouter_key_here
